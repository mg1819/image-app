# Copy this file to .env and fill in real values.
# NOTE: Vite inlines VITE_* vars into the client bundle. Anything here is
# visible to anyone who loads the page — never put server secrets here.

VITE_WEBHOOK_URL=http://localhost:5678/webhook/your-webhook-id-here
VITE_REQUEST_TIMEOUT_MS=120000
VITE_MAX_UPLOAD_BYTES=5242880
VITE_MAX_RESPONSE_BYTES=20971520
