# Copy this file to .env and fill in real values.
# NOTE: Vite inlines VITE_* vars into the client bundle. Anything here is
# visible to anyone who loads the page — never put server secrets here.

VITE_WEBHOOK_URL=http://localhost:5678/webhook/your-webhook-id-here
VITE_REQUEST_TIMEOUT_MS=120000
VITE_MAX_UPLOAD_BYTES=5242880
VITE_MAX_RESPONSE_BYTES=20971520

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# Stripe Payment Link (Stripe Dashboard → Payment Links). Must redirect back
# to this app's origin with ?paid=1&session_id={CHECKOUT_SESSION_ID}.
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_xxx
